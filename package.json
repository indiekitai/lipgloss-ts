{
  "name": "@indiekitai/lipgloss",
  "version": "0.1.0",
  "description": "Terminal styling & layout for TypeScript - port of charmbracelet/lipgloss",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "lipgloss": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx src/cli.ts"
  },
  "keywords": ["terminal", "styling", "ansi", "lipgloss", "tui", "layout"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/indiekitai/lipgloss"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0",
    "tsx": "^4.0.0"
  }
}
